# ─────────────────────────────────────────────────────────────────────────────
# Memorable Pictures — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_CDN_URL=https://your-zone.b-cdn.net
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/memorablepictures?retryWrites=true&w=majority

# ── JWT secrets (use different values for each) ───────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_long_random_string_min_32_chars
SUPER_JWT_SECRET=CHANGE_ME_different_long_random_string

# ── Super Admin (SaaS owner) ──────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=your-real-superadmin@yourdomain.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Bunny.net CDN & Storage ───────────────────────────────────────────────────
# Get from: https://panel.bunny.net → Storage → your zone → FTP & API Access
BUNNY_ACCESS_KEY=your-bunny-api-key
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_STORAGE_HOST=https://storage.bunnycdn.com
BUNNY_CDN_URL=https://your-zone.b-cdn.net
# Get from: https://panel.bunny.net → CDN → your pull zone → Security → Token Authentication
BUNNY_TOKEN_KEY=your-bunny-token-auth-key

# ── Telemetry (optional) ──────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
